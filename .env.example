# Public client (MSAL popup)
# Use /okr for the classic board or /ease-okr for the EASE hierarchy board.
NEXT_PUBLIC_BASE_PATH=/okr
NEXT_PUBLIC_APP_PROFILE=classic
NEXT_PUBLIC_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AAD_TENANT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000
NEXT_PUBLIC_LOGIN_SCOPES=openid profile email User.Read Sites.Read.All
NEXT_PUBLIC_SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/YourSite
NEXT_PUBLIC_SHAREPOINT_STORAGE_LIST=OKR Follow Up Store

# Example EASE deployment on the same SharePoint site:
# NEXT_PUBLIC_BASE_PATH=/ease-okr
# NEXT_PUBLIC_APP_PROFILE=ease-okr
# NEXT_PUBLIC_SHAREPOINT_STORAGE_LIST=EASE OKR Store

# Server-side SharePoint list persistence (client credentials)
AZURE_APP_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_APP_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_APP_CLIENT_SECRET=your-client-secret
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/YourSite
SHAREPOINT_STORAGE_LIST=OKR Follow Up Store

# Example EASE deployment on the same SharePoint site:
# SHAREPOINT_STORAGE_LIST=EASE OKR Store

# Optional LN-style fallback names
# REACT_APP_AZURE_CLIENT_ID=
# REACT_APP_AAD_TENANT_ID=
# REACT_APP_AZURE_AUTHORITY=
# REACT_APP_REDIRECT_URI=
# REACT_APP_POST_LOGOUT_REDIRECT_URI=
# REACT_APP_LOGIN_SCOPES=
# REACT_APP_SHAREPOINT_SITE_URL=
